# ── Helm dependency artifacts ─────────────────────────────────────────────
# Chart.lock and charts/ tarballs are generated by `helm dep update`.
# Commit them if you want reproducible offline builds; otherwise gitignore.
# For this project we commit them so ArgoCD doesn't need internet access.
# Uncomment the lines below to exclude them instead:
# **/Chart.lock
# **/charts/*.tgz

# ── NEVER commit these ────────────────────────────────────────────────────

# Vault initialization output (contains unseal keys + root token)
vault-init.json
vault-init-output.json
*.vault-init*

# Talos-generated cluster configs (contain machine secrets / cluster CA)
talos/generated/
*.talosconfig

# Kubeconfig
kubeconfig
*.kubeconfig

# Any local override values (may contain real IPs or test credentials)
values.local.yaml
values.override.yaml
*-local.yaml
*-override.yaml

# Environment files
.env
.env.*
*.env

# Editor / OS artifacts
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/settings.json
