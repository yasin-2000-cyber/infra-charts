# ── Helm dependency artifacts ─────────────────────────────────────────────
# Chart.lock and charts/ tarballs are generated by `helm dep update`.
# Commit them if you want reproducible offline builds; otherwise gitignore.
# For this project we commit them so ArgoCD doesn't need internet access.
# Uncomment the lines below to exclude them instead:
# **/Chart.lock
# **/charts/*.tgz

# ── Hub-only dirs — not used on spine-gitops branch ─────────────────────
# These live on main and are managed there. Excluded here to keep the
# spine-gitops branch focused on spoke content only.
# Leading / anchors patterns to repo root so they don't accidentally match
# same-named dirs inside spokes/ (e.g. spokes/spine-test/metallb/).
/alertmanager/
/argo-cd/
/argocd/
/bootstrap/
/cert-manager/
/external-secrets/
/grafana/
/ingress-nginx/
/loki/
/longhorn/
/metallb/
/mimir/
/talos/
/tempo/
/trust-manager/
/vault/

# ── NEVER commit these ────────────────────────────────────────────────────

# Vault initialization output (contains unseal keys + root token)
vault-init.json
vault-init-output.json
*.vault-init*

# Talos-generated cluster configs (contain machine secrets / cluster CA)
talos/generated/
spokes/*/talos/generated/
*.talosconfig

# Kubeconfig
kubeconfig
*.kubeconfig

# Any local override values (may contain real IPs or test credentials)
values.local.yaml
values.override.yaml
*-local.yaml
*-override.yaml

# Environment files
.env
.env.*
*.env

# Editor / OS artifacts
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/settings.json
